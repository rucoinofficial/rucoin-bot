"""
RuCoin Telegram Bot
Репозиторий: github.com/rucoinofficial/rucoin-bot
"""

import logging
import os
import sys
import time

import requests
from dotenv import load_dotenv
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    Application,
    CommandHandler,
    CallbackQueryHandler,
    ContextTypes,
)

# ── Загрузка конфига ──────────────────────────────────────────────────────────
load_dotenv()

TOKEN    = os.getenv("BOT_TOKEN")
CONTRACT = os.getenv("CONTRACT",  "0x4d870Ae52e61d4FB6e125f4380cC0c0F9f15A575")
NETWORK  = os.getenv("NETWORK",   "polygon_pos")
SITE_URL = os.getenv("SITE_URL",  "https://rucoinofficial.github.io/rucoin")
TG_URL   = os.getenv("TG_URL",    "https://t.me/RuCoin_RUS")

if not TOKEN:
    sys.exit("❌  BOT_TOKEN не задан. Создайте файл .env (см. .env.example)")

BUY_URL = f"https://quickswap.exchange/#/swap?currency0=ETH&currency1={CONTRACT}&swapIndex=0"
GECKO_URL  = (
    f"https://api.geckoterminal.com/api/v2/networks/{NETWORK}/tokens/{CONTRACT}"
)

# ── Логирование ───────────────────────────────────────────────────────────────
logging.basicConfig(
    format="%(asctime)s | %(levelname)s | %(name)s | %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
    level=logging.INFO,
)
logger = logging.getLogger(__name__)

# ── Кэш цены (обновляется не чаще раза в минуту) ─────────────────────────────
_price_cache: dict = {"value": None, "ts": 0.0}
CACHE_TTL = 60  # секунд


def get_price() -> str:
    now = time.monotonic()
    if _price_cache["value"] and now - _price_cache["ts"] < CACHE_TTL:
        return _price_cache["value"]

    for attempt in range(3):
        try:
            r = requests.get(GECKO_URL, timeout=5)
            r.raise_for_status()
            data = r.json()
            price = float(data["data"]["attributes"]["price_usd"])
            result = f"${price:.6f}"
            _price_cache["value"] = result
            _price_cache["ts"]    = now
            return result
        except Exception as exc:
            logger.warning("get_price попытка %d/3: %s", attempt + 1, exc)
            if attempt < 2:
                time.sleep(1)

    return "⚠️ Нет данных"


# ── Клавиатура главного меню ──────────────────────────────────────────────────
def main_keyboard() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("🪙 Купить RuCoin",        url=BUY_URL)],
        [InlineKeyboardButton("📊 Текущая цена",         callback_data="price")],
        [InlineKeyboardButton("🦊 Добавить в MetaMask",  callback_data="metamask")],
        [InlineKeyboardButton("🌐 Сайт",                 url=SITE_URL),
         InlineKeyboardButton("📢 Канал",                url=TG_URL)],
    ])


WELCOME_TEXT = (
    "👋 Добро пожаловать в <b>RuCoin</b>!\n\n"
    "🔷 Контракт:\n<code>{contract}</code>\n"
    "🔷 Сеть: <b>Polygon (MATIC)</b>\n\n"
    "Выберите действие:"
)


# ── Хендлеры ─────────────────────────────────────────────────────────────────
async def cmd_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    text = WELCOME_TEXT.format(contract=CONTRACT)
    if update.message:
        await update.message.reply_text(
            text, reply_markup=main_keyboard(), parse_mode="HTML"
        )
    elif update.callback_query:
        await update.callback_query.message.edit_text(
            text, reply_markup=main_keyboard(), parse_mode="HTML"
        )


async def cmd_price(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    price = get_price()
    await update.message.reply_text(
        f"📊 Текущая цена <b>RuCoin</b>: <b>{price}</b>",
        parse_mode="HTML",
    )


async def on_button(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    query = update.callback_query
    await query.answer()

    back_kb = InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="back")]])

    if query.data == "price":
        price = get_price()
        await query.message.edit_text(
            f"📊 Текущая цена <b>RuCoin</b>:\n\n💰 <b>{price}</b>",
            reply_markup=back_kb,
            parse_mode="HTML",
        )

    elif query.data == "metamask":
        text = (
            "🦊 <b>Добавить RuCoin в MetaMask</b>\n\n"
            f"Сеть: <b>Polygon (MATIC)</b>\n"
            f"Адрес контракта:\n<code>{CONTRACT}</code>\n"
            "Символ: <b>RUC</b>\n"
            "Десятичных знаков: <b>18</b>"
        )
        await query.message.edit_text(text, reply_markup=back_kb, parse_mode="HTML")

    elif query.data == "back":
        await cmd_start(update, context)


async def on_error(update: object, context: ContextTypes.DEFAULT_TYPE) -> None:
    logger.error("Необработанная ошибка: %s", context.error, exc_info=context.error)


# ── Запуск ────────────────────────────────────────────────────────────────────
def main() -> None:
    app = Application.builder().token(TOKEN).build()

    app.add_handler(CommandHandler("start", cmd_start))
    app.add_handler(CommandHandler("price", cmd_price))
    app.add_handler(CallbackQueryHandler(on_button))
    app.add_error_handler(on_error)

    logger.info("✅ Бот @RuCoin_RUS_Bot запущен")
    app.run_polling(allowed_updates=Update.ALL_TYPES)


if __name__ == "__main__":
    main()
